{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "public": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "env": {
    "ADMIN_PASSWORD": "@admin-password"
  }
}
